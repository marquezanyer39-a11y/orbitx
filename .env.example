EXPO_PUBLIC_TRANSAK_REFERRER_DOMAIN=app.orbitx.com
EXPO_PUBLIC_MOONPAY_API_KEY=your-moonpay-api-key
EXPO_PUBLIC_MOONPAY_QUOTE_ENDPOINT=https://your-backend.example.com/ramp/moonpay/quote
EXPO_PUBLIC_MOONPAY_WIDGET_SESSION_URL=https://your-backend.example.com/ramp/moonpay/session
