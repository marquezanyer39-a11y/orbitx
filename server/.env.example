HOST=0.0.0.0
PORT=8788
CORS_ALLOWED_ORIGINS=*

# Required
ELEVENLABS_API_KEY=your-elevenlabs-api-key
GEMINI_API_KEY=your-gemini-api-key

# Conversational brain
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=18000
GEMINI_MAX_QUESTION_LENGTH=900
GEMINI_MAX_RESPONSE_LENGTH=700

# Astra visual generation with Gemini / Nano Banana
# Primary key source: GEMINI_API_KEY
# Optional fallback key source: NANOBANANA_API_KEY
NANOBANANA_API_URL=https://generativelanguage.googleapis.com
NANOBANANA_API_KEY=
NANOBANANA_MODEL=gemini-2.5-flash-image
NANOBANANA_TIMEOUT_MS=30000

# Frontend should point EXPO_PUBLIC_ORBITX_BACKEND_URL to this public server URL.
# Example public URL after deploying to Render or Railway:
# EXPO_PUBLIC_ORBITX_BACKEND_URL=https://your-backend.example.com
# Legacy compatibility only if an older build still expects it:
# EXPO_PUBLIC_ASTRA_VOICE_API_URL=https://your-backend.example.com

# Global defaults
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
ELEVENLABS_VOICE_ID=your-primary-voice-id
ELEVENLABS_FALLBACK_VOICE_ID=your-fallback-voice-id
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_FALLBACK_MODEL_ID=eleven_flash_v2
ELEVENLABS_DEFAULT_PRESET_ID=astra_nova
ELEVENLABS_FALLBACK_PRESET_ID=astra_pulse
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_REQUEST_TIMEOUT_MS=20000
ELEVENLABS_MAX_TEXT_LENGTH=520

# Optional per-preset overrides
ELEVENLABS_ASTRA_CORE_VOICE_ID=
ELEVENLABS_ASTRA_EDGE_VOICE_ID=
ELEVENLABS_ASTRA_NOVA_VOICE_ID=
ELEVENLABS_ASTRA_PULSE_VOICE_ID=

ELEVENLABS_ASTRA_CORE_MODEL_ID=
ELEVENLABS_ASTRA_EDGE_MODEL_ID=
ELEVENLABS_ASTRA_NOVA_MODEL_ID=
ELEVENLABS_ASTRA_PULSE_MODEL_ID=

# Voice shaping defaults
ELEVENLABS_STABILITY=0.68
ELEVENLABS_SIMILARITY_BOOST=0.82
ELEVENLABS_STYLE=0.14
ELEVENLABS_SPEED=0.96
ELEVENLABS_USE_SPEAKER_BOOST=true
