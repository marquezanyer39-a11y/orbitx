EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Local development only. Use your machine LAN IP if you want to test against a backend
# running on your computer while both devices are on the same Wi-Fi.
EXPO_PUBLIC_ORBITX_BACKEND_URL=http://192.168.18.30:8788

